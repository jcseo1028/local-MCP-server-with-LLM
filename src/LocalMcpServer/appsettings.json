{
  "Server": {
    "Host": "localhost",
    "Port": 5100,
    "Transport": "sse"
  },
  "Llm": {
    "Provider": "ollama",
    "Endpoint": "http://localhost:11434",
    "DefaultModel": "qwen2.5-coder:7b",
    "GeneralModel": "qwen2.5-coder:7b",
    "SummaryModel": "qwen2.5-coder:7b",
    "LargeFileModel": "qwen2.5-coder:32b",
    "RequestTimeoutMinutes": 20
  },
  "Rag": {
    "Enabled": true,
    "DbPath": "",
    "MinFileLineCount": 500,
    "TopKChunks": 5,
    "SimilarityThreshold": 0.5,
    "MaxContextChars": 5000,
    "EmbeddingModel": "nomic-embed-text"
  },
  "Tools": {
    "Directory": "tools",
    "PromptsDirectory": "prompts"
  },
  "Chat": {
    "IntentModel": "qwen2.5-coder:7b",
    "ChatModel": "gemma4",
    "ConversationTimeoutMinutes": 30,
    "MaxConversationHistory": 20,
    "IntentAndPlanOnly": false
  },
  "DocumentSearch": {
    "Directories": [],
    "FilePatterns": [ "*.md", "*.txt" ]
  },
  "Build": {
    "OfflineMode": true,
    "SolutionPath": null
  },
  "Cache": {
    "Directory": "",
    "Categories": [ "standards", "api_references", "snippets", "best_practices" ]
  },
  "CodeIndex": {
    "RootPath": "",
    "FilePatterns": [ "*.cs", "*.xaml" ],
    "Strategy": "hybrid"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
